<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>enrich_research_data</name>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
  </info>
  <order>
    <hop>
      <from>Ler Staging Grupos</from>
      <to>Tratar UF</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tratar UF</from>
      <to>Inserir/Atualizar UF</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Inserir/Atualizar UF</from>
      <to>Tratar Instituicao</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tratar Instituicao</from>
      <to>Lookup UF ID</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup UF ID</from>
      <to>Inserir/Atualizar Instituicao</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Inserir/Atualizar Instituicao</from>
      <to>Tratar Area</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tratar Area</from>
      <to>Inserir/Atualizar Area Conhecimento</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  
  <transform>
    <name>Ler Staging Grupos</name>
    <type>TableInput</type>
    <connection>oda_db</connection>
    <sql>SELECT dgp_id, instituicao_nome as instituicao, uf, area_predominante as area FROM stg_grupo_pesquisa</sql>
    <GUI>
      <xloc>100</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tratar UF</name>
    <type>StringOperations</type>
    <fields>
      <field>
        <in_stream_name>uf</in_stream_name>
        <trim_type>both</trim_type>
        <lower_upper>upper</lower_upper>
      </field>
    </fields>
    <GUI>
      <xloc>250</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar UF</name>
    <type>InsertUpdate</type>
    <connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>uf</table>
      <key>
        <name>uf</name>
        <field>sigla</field>
        <condition>=</condition>
      </key>
      <value>
        <name>sigla</name>
        <rename>uf</rename>
        <update>N</update>
      </value>
      <value>
        <name>nome</name>
        <rename>uf</rename>
        <update>N</update>
      </value>
    </lookup>
    <GUI>
      <xloc>400</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tratar Instituicao</name>
    <type>StringOperations</type>
    <fields>
      <field>
        <in_stream_name>instituicao</in_stream_name>
        <trim_type>both</trim_type>
        <lower_upper>upper</lower_upper>
      </field>
    </fields>
    <GUI>
      <xloc>550</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Lookup UF ID</name>
    <type>DBLookup</type>
    <connection>oda_db</connection>
    <lookup>
      <table>uf</table>
      <key>
        <name>uf</name>
        <field>sigla</field>
        <condition>=</condition>
      </key>
      <value>
        <name>id</name>
        <rename>uf_id</rename>
        <default/>
        <type>String</type>
      </value>
    </lookup>
    <GUI>
      <xloc>700</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar Instituicao</name>
    <type>InsertUpdate</type>
    <connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>instituicao</table>
      <key>
        <name>instituicao</name>
        <field>nome</field>
        <condition>=</condition>
      </key>
      <value>
        <name>nome</name>
        <rename>instituicao</rename>
        <update>Y</update>
      </value>
      <value>
        <name>sigla</name>
        <rename>instituicao</rename>
        <update>N</update>
      </value>
      <value>
        <name>uf_id</name>
        <rename>uf_id</rename>
        <update>Y</update>
      </value>
    </lookup>
    <GUI>
      <xloc>850</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tratar Area</name>
    <type>StringOperations</type>
    <fields>
      <field>
        <in_stream_name>area</in_stream_name>
        <trim_type>both</trim_type>
      </field>
    </fields>
    <GUI>
      <xloc>1000</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar Area Conhecimento</name>
    <type>InsertUpdate</type>
    <connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>area_conhecimento</table>
      <key>
        <name>area</name>
        <field>nome</field>
        <condition>=</condition>
      </key>
      <value>
        <name>nome</name>
        <rename>area</rename>
        <update>Y</update>
      </value>
    </lookup>
    <GUI>
      <xloc>1150</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
</pipeline>
