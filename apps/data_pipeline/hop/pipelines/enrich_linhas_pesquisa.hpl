<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>enrich_linhas_pesquisa</name>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
  </info>
  <order>
    <hop>
      <from>Ler Staging Linhas</from>
      <to>Lookup Grupo ID</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup Grupo ID</from>
      <to>Inserir/Atualizar Linha</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Inserir/Atualizar Linha</from>
      <to>Split Palavras-Chave</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Split Palavras-Chave</from>
      <to>Tratar Palavra-Chave</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tratar Palavra-Chave</from>
      <to>Filter Empty Palavras</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filter Empty Palavras</from>
      <to>Inserir/Atualizar Palavra-Chave</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Inserir/Atualizar Palavra-Chave</from>
      <to>Link Linha-Palavra</to>
      <enabled>Y</enabled>
    </hop>
    
    <hop>
      <from>Inserir/Atualizar Linha</from>
      <to>Split Setores</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Split Setores</from>
      <to>Tratar Setor</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tratar Setor</from>
      <to>Filter Empty Setores</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filter Empty Setores</from>
      <to>Inserir/Atualizar Setor</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Inserir/Atualizar Setor</from>
      <to>Link Linha-Setor</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  
  <transform>
    <name>Ler Staging Linhas</name>
    <type>TableInput</type>
    <connection>oda_db</connection>
    <sql>SELECT dgp_id, titulo, objetivo, setor_aplicacao, palavra_chave FROM stg_linha_pesquisa</sql>
    <GUI>
      <xloc>100</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Lookup Grupo ID</name>
    <type>DBLookup</type>
    <connection>oda_db</connection>
    <lookup>
      <table>grupo_pesquisa</table>
      <key>
        <name>dgp_id</name>
        <field>dgp_id</field>
        <condition>=</condition>
      </key>
      <value>
        <name>id</name>
        <rename>grupo_id</rename>
        <default/>
        <type>String</type>
      </value>
    </lookup>
    <GUI>
      <xloc>250</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar Linha</name>
    <type>InsertUpdate</type>
    <connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>linha_pesquisa</table>
      <key>
        <name>titulo</name>
        <field>titulo</field>
        <condition>=</condition>
      </key>
      <key>
        <name>grupo_id</name>
        <field>grupo_id</field>
        <condition>=</condition>
      </key>
      <value>
        <name>titulo</name>
        <rename>titulo</rename>
        <update>Y</update>
      </value>
      <value>
        <name>objetivo</name>
        <rename>objetivo</rename>
        <update>Y</update>
      </value>
      <value>
        <name>grupo_id</name>
        <rename>grupo_id</rename>
        <update>Y</update>
      </value>
    </lookup>
    <GUI>
      <xloc>400</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>

  <!-- Processamento de Palavras-Chave -->
  <transform>
    <name>Split Palavras-Chave</name>
    <type>SplitFieldToRows3</type>
    <delimiter>\|</delimiter>
    <delimiter_is_regex>N</delimiter_is_regex>
    <newfield>palavra_chave_split</newfield>
    <splitfield>palavra_chave</splitfield>
    <GUI>
      <xloc>550</xloc>
      <yloc>50</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tratar Palavra-Chave</name>
    <type>StringOperations</type>
    <fields>
      <field>
        <in_stream_name>palavra_chave_split</in_stream_name>
        <trim_type>both</trim_type>
        <lower_upper>lower</lower_upper>
      </field>
    </fields>
    <GUI>
      <xloc>700</xloc>
      <yloc>50</yloc>
    </GUI>
  </transform>
  
  <transform>
    <name>Filter Empty Palavras</name>
    <type>FilterRows</type>
    <send_true_to>Inserir/Atualizar Palavra-Chave</send_true_to>
    <send_false_to/>
    <condition>
      <negated>N</negated>
      <leftvalue>palavra_chave_split</leftvalue>
      <function>IS NOT NULL</function>
    </condition>
    <GUI>
      <xloc>850</xloc>
      <yloc>50</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar Palavra-Chave</name>
    <type>InsertUpdate</type>
    <connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>palavra_chave</table>
      <key>
        <name>palavra_chave_split</name>
        <field>termo_normalizado</field>
        <condition>=</condition>
      </key>
      <value>
        <name>termo</name>
        <rename>palavra_chave_split</rename>
        <update>Y</update>
      </value>
      <value>
        <name>termo_normalizado</name>
        <rename>palavra_chave_split</rename>
        <update>Y</update>
      </value>
    </lookup>
    <GUI>
      <xloc>1000</xloc>
      <yloc>50</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Link Linha-Palavra</name>
    <type>ExecSQL</type>
    <connection>oda_db</connection>
    <execute_each_row>Y</execute_each_row>
    <sql>
      INSERT INTO linha_pesquisa_palavra_chave (linha_pesquisa_id, palavra_chave_id)
      SELECT lp.id, pc.id
      FROM linha_pesquisa lp, palavra_chave pc
      WHERE lp.titulo = ? AND lp.grupo_id = ? AND pc.termo_normalizado = ?
      ON CONFLICT DO NOTHING;
    </sql>
    <arguments>
      <argument>
        <name>titulo</name>
      </argument>
      <argument>
        <name>grupo_id</name>
      </argument>
      <argument>
        <name>palavra_chave_split</name>
      </argument>
    </arguments>
    <GUI>
      <xloc>1150</xloc>
      <yloc>50</yloc>
    </GUI>
  </transform>

  <!-- Processamento de Setores de Aplicação -->
  <transform>
    <name>Split Setores</name>
    <type>SplitFieldToRows3</type>
    <delimiter>\|</delimiter>
    <delimiter_is_regex>N</delimiter_is_regex>
    <newfield>setor_split</newfield>
    <splitfield>setor_aplicacao</splitfield>
    <GUI>
      <xloc>550</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tratar Setor</name>
    <type>StringOperations</type>
    <fields>
      <field>
        <in_stream_name>setor_split</in_stream_name>
        <trim_type>both</trim_type>
        <lower_upper>lower</lower_upper>
      </field>
    </fields>
    <GUI>
      <xloc>700</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Filter Empty Setores</name>
    <type>FilterRows</type>
    <send_true_to>Inserir/Atualizar Setor</send_true_to>
    <send_false_to/>
    <condition>
      <negated>N</negated>
      <leftvalue>setor_split</leftvalue>
      <function>IS NOT NULL</function>
    </condition>
    <GUI>
      <xloc>850</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar Setor</name>
    <type>InsertUpdate</type>
    <connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>setor_aplicacao</table>
      <key>
        <name>setor_split</name>
        <field>nome_normalizado</field>
        <condition>=</condition>
      </key>
      <value>
        <name>nome</name>
        <rename>setor_split</rename>
        <update>Y</update>
      </value>
      <value>
        <name>nome_normalizado</name>
        <rename>setor_split</rename>
        <update>Y</update>
      </value>
    </lookup>
    <GUI>
      <xloc>1000</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Link Linha-Setor</name>
    <type>ExecSQL</type>
    <connection>oda_db</connection>
    <execute_each_row>Y</execute_each_row>
    <sql>
      INSERT INTO linha_pesquisa_setor_aplicacao (linha_pesquisa_id, setor_aplicacao_id)
      SELECT lp.id, sa.id
      FROM linha_pesquisa lp, setor_aplicacao sa
      WHERE lp.titulo = ? AND lp.grupo_id = ? AND sa.nome_normalizado = ?
      ON CONFLICT DO NOTHING;
    </sql>
    <arguments>
      <argument>
        <name>titulo</name>
      </argument>
      <argument>
        <name>grupo_id</name>
      </argument>
      <argument>
        <name>setor_split</name>
      </argument>
    </arguments>
    <GUI>
      <xloc>1150</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>
</pipeline>
