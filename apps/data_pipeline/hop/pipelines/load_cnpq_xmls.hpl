<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>load_cnpq_xmls</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2024/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2024/01/01 00:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <note>ETL inicial: 
1. Listar arquivos XML
2. Extrair dados de Grupos e Pesquisadores
3. Salvar em tabelas de staging</note>
      <xloc>64</xloc>
      <yloc>48</yloc>
      <width>250</width>
      <height>70</height>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Pegar XMLs</from>
      <to>Extrair Grupos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Grupos</from>
      <to>Staging Grupo Pesquisa</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Pegar XMLs</from>
      <to>Extrair Pesquisadores</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Pesquisadores</from>
      <to>Staging Pesquisadores</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Pegar XMLs</from>
      <to>Extrair Linhas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Linhas</from>
      <to>Staging Linhas</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Pegar XMLs</name>
    <type>GetFileNames</type>
    <description/>
    <distribute>N</distribute>
    <copies>1</copies>
    <file>
      <name>${PROJECT_HOME}/data</name>
      <filemask>.*\.xml</filemask>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <GUI>
      <xloc>100</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Extrair Grupos</name>
    <type>getXMLData</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <XmlField>filename</XmlField>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <loopxpath>/DIRETORIO_DE_GRUPOS/GRUPO_DE_PESQUISA</loopxpath>
    <fields>
      <field>
        <name>nome_grupo</name>
        <xpath>NOME</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>dgp_id</name>
        <xpath>IDENTIFICACAO_DGP</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>repercussao</name>
        <xpath>REPERCUSSAO</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>area_predominante</name>
        <xpath>AREA</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>instituicao</name>
        <xpath>INSTITUICAO</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>ano_formacao</name>
        <xpath>ANO_FORMACAO</xpath>
        <element_type>node</element_type>
        <type>Integer</type>
      </field>
      <field>
        <name>uf</name>
        <xpath>ENDERECO/UF</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
    </fields>
    <GUI>
      <xloc>300</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Staging Grupo Pesquisa</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <connection>oda_db</connection>
    <schema/>
    <table>stg_grupo_pesquisa</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <fields>
      <field>
        <column_name>nome</column_name>
        <stream_name>nome_grupo</stream_name>
      </field>
      <field>
        <column_name>dgp_id</column_name>
        <stream_name>dgp_id</stream_name>
      </field>
      <field>
        <column_name>repercussao</column_name>
        <stream_name>repercussao</stream_name>
      </field>
      <field>
        <column_name>area_predominante</column_name>
        <stream_name>area_predominante</stream_name>
      </field>
      <field>
        <column_name>instituicao_nome</column_name>
        <stream_name>instituicao</stream_name>
      </field>
      <field>
        <column_name>ano_formacao</column_name>
        <stream_name>ano_formacao</stream_name>
      </field>
      <field>
        <column_name>uf</column_name>
        <stream_name>uf</stream_name>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Extrair Pesquisadores</name>
    <type>getXMLData</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <XmlField>filename</XmlField>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <loopxpath>/DIRETORIO_DE_GRUPOS/GRUPO_DE_PESQUISA/PESQUISADORES/PESQUISADOR</loopxpath>
    <fields>
      <field>
        <name>nome_pesquisador</name>
        <xpath>@NOME</xpath>
        <element_type>attribut</element_type>
        <type>String</type>
      </field>
      <field>
        <name>lattes_id</name>
        <xpath>@LATTES</xpath>
        <element_type>attribut</element_type>
        <type>String</type>
      </field>
      <field>
        <name>formacao</name>
        <xpath>@FORMACAO_ACADEMICA</xpath>
        <element_type>attribut</element_type>
        <type>String</type>
      </field>
      <field>
        <name>categoria</name>
        <xpath>@CATEGORIA</xpath>
        <element_type>attribut</element_type>
        <type>String</type>
      </field>
      <field>
        <name>dgp_id</name>
        <xpath>../../IDENTIFICACAO_DGP</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
    </fields>
    <GUI>
      <xloc>300</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Staging Pesquisadores</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <connection>oda_db</connection>
    <schema/>
    <table>stg_pesquisador</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <fields>
      <field>
        <column_name>nome</column_name>
        <stream_name>nome_pesquisador</stream_name>
      </field>
      <field>
        <column_name>lattes_id</column_name>
        <stream_name>lattes_id</stream_name>
      </field>
      <field>
        <column_name>formacao</column_name>
        <stream_name>formacao</stream_name>
      </field>
      <field>
        <column_name>categoria</column_name>
        <stream_name>categoria</stream_name>
      </field>
      <field>
        <column_name>dgp_id</column_name>
        <stream_name>dgp_id</stream_name>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Extrair Linhas</name>
    <type>getXMLData</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <XmlField>filename</XmlField>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <loopxpath>/DIRETORIO_DE_GRUPOS/GRUPO_DE_PESQUISA/LINHAS_DE_PESQUISA/LINHA_DE_PESQUISA</loopxpath>
    <fields>
      <field>
        <name>dgp_id</name>
        <xpath>../../IDENTIFICACAO_DGP</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>titulo</name>
        <xpath>NOME</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>objetivo</name>
        <xpath>OBJETIVO</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>setor_aplicacao</name>
        <xpath>SETOR_APLICACAO</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
      <field>
        <name>palavra_chave</name>
        <xpath>PALAVRA_CHAVE</xpath>
        <element_type>node</element_type>
        <type>String</type>
      </field>
    </fields>
    <GUI>
      <xloc>300</xloc>
      <yloc>350</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Staging Linhas</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <connection>oda_db</connection>
    <schema/>
    <table>stg_linha_pesquisa</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <fields>
      <field>
        <column_name>dgp_id</column_name>
        <stream_name>dgp_id</stream_name>
      </field>
      <field>
        <column_name>titulo</column_name>
        <stream_name>titulo</stream_name>
      </field>
      <field>
        <column_name>objetivo</column_name>
        <stream_name>objetivo</stream_name>
      </field>
      <field>
        <column_name>setor_aplicacao</column_name>
        <stream_name>setor_aplicacao</stream_name>
      </field>
      <field>
        <column_name>palavra_chave</column_name>
        <stream_name>palavra_chave</stream_name>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>350</yloc>
    </GUI>
  </transform>
</pipeline>
