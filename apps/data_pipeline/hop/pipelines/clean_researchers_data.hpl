<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>clean_researchers_data</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Pipeline para limpeza e padronização de dados dos pesquisadores.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2024/06/05 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2024/06/05 00:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <backgroundcolorblue>251</backgroundcolorblue>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorred>201</backgroundcolorred>
      <bordercolorblue>90</bordercolorblue>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorred>14</bordercolorred>
      <fontbold>N</fontbold>
      <fontcolorblue>90</fontcolorblue>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorred>14</fontcolorred>
      <fontitalic>N</fontitalic>
      <fontname>Segoe UI</fontname>
      <fontsize>9</fontsize>
      <height>42</height>
      <xloc>64</xloc>
      <yloc>48</yloc>
      <note>Limpeza de Pesquisadores:
1. Padronização do Lattes ID (remover espaços/traços).
2. Padronização de nomes.
3. Tratamento de campos de formação acadêmica.</note>
      <width>322</width>
    </notepad>
  </notepads>
  <transform>
    <name>Read Mock Researchers</name>
    <type>DataGrid</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>lattes_id</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <name>nome_pesquisador</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <data>
      <line>
        <item>1234 5678 9012 3456</item>
        <item>João da Silva</item>
      </line>
    </data>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Replace in string</name>
    <type>ReplaceString</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <in_stream_name>lattes_id</in_stream_name>
        <out_stream_name/>
        <use_regex>yes</use_regex>
        <replace_string>\s+</replace_string>
        <replace_by_string/>
        <set_empty_string>N</set_empty_string>
        <replace_field_by_string/>
        <whole_word>no</whole_word>
        <case_sensitive>no</case_sensitive>
        <is_unicode>no</is_unicode>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>288</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <attributes/>
</pipeline>
