// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  moduleFormat    = "esm"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// Domínio da API
model Instituicao {
  id             String          @id @default(uuid())
  nome           String
  sigla          String
  estado             Estado?             @relation(fields: [estadoId], references: [id])
  estadoId           String?         @map("estado_id")
  gruposPesquisa GrupoPesquisa[]
  criadoEm       DateTime        @default(now()) @map("criado_em")
  atualizadoEm   DateTime        @updatedAt @map("atualizado_em")

  @@map("instituicao")
}

model Estado {
  id           String        @id @default(uuid())
  sigla        String        @unique
  nome         String
  regiao       String
  instituicoes Instituicao[]
  criadoEm     DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime      @updatedAt @map("atualizado_em")

  @@map("estado")
}

enum Situacao {
  ATIVO      @map("certificado")
  INATIVO    @map("inativo")
  EM_ANALISE @map("em_analise")

  @@map("situacao")
}

model GrupoPesquisa {
  id                 String            @id @default(uuid())
  dgpId              String?           @unique @map("dgp_id")
  nome               String
  anoFormacao        Int?              @map("ano_formacao")
  areaPredominante   String            @map("area_predominante")
  repercussao        String?
  areaConhecimento   AreaConhecimento? @relation(fields: [areaConhecimentoId], references: [id])
  areaConhecimentoId String?           @map("area_conhecimento_id")
  situacao           Situacao          @default(ATIVO)
  instituicao        Instituicao       @relation(fields: [instituicaoId], references: [id])
  instituicaoId      String            @map("instituicao_id")
  membros            MembroGrupo[]
  linhasPesquisa     LinhaPesquisa[]
  logColeta          LogColetaItem[]   @relation("GrupoLogs")
  criadoEm           DateTime          @default(now()) @map("criado_em")
  atualizadoEm       DateTime          @updatedAt @map("atualizado_em")

  @@map("grupo_pesquisa")
}

model LinhaPesquisa {
  id               String                        @id @default(uuid())
  titulo           String
  objetivo         String?
  grupo            GrupoPesquisa                 @relation(fields: [grupoId], references: [id])
  grupoId          String                        @map("grupo_id")
  membros          MembroLinhaPesquisa[]
  palavrasChave    LinhaPesquisaPalavraChave[]
  setoresAplicacao LinhaPesquisaSetorAplicacao[]
  criadoEm         DateTime                      @default(now()) @map("criado_em")
  atualizadoEm     DateTime                      @updatedAt @map("atualizado_em")

  @@map("linha_pesquisa")
}

enum TipoPesquisador {
  TECNICO                 @map("tecnico")
  ESTUDANTE               @map("estudante")
  PESQUISADOR             @map("pesquisador")
  COLABORADOR_ESTRANGEIRO @map("colaborador_estrangeiro")

  @@map("tipo_pesquisador")
}

enum FormacaoAcademica {
  GRADUACAO      @map("graduacao")
  ESPECIALIZACAO @map("especializacao")
  MESTRADO       @map("mestrado")
  DOUTORADO      @map("doutorado")

  @@map("formacao_academica")
}

model Pesquisador {
  id                   String                   @id @default(uuid())
  lattesId             String?                  @unique @map("lattes_id")
  nome                 String
  tipo                 TipoPesquisador?
  formacaoAcademica    FormacaoAcademica?       @map("formacao_academica")
  membrosGrupo         MembroGrupo[]
  membrosLinhaPesquisa MembroLinhaPesquisa[]
  producoes            ProducaoPesquisador[]
  logColeta            LogColetaItem[] @relation("PesquisadorLogs")
  areasAtuacao         PesquisadorAreaAtuacao[]
  criadoEm             DateTime                 @default(now()) @map("criado_em")
  atualizadoEm         DateTime                 @updatedAt @map("atualizado_em")

  @@map("pesquisador")
}

model AreaAtuacao {
  id               String                   @id @default(uuid())
  nome             String                   @unique
  nomeNormalizado  String                   @unique @map("nome_normalizado")
  pesquisadores    PesquisadorAreaAtuacao[]
  criadoEm         DateTime                 @default(now()) @map("criado_em")
  atualizadoEm     DateTime                 @updatedAt @map("atualizado_em")

  @@map("area_atuacao")
}

model PesquisadorAreaAtuacao {
  pesquisador   Pesquisador @relation(fields: [pesquisadorId], references: [id])
  pesquisadorId String      @map("pesquisador_id")
  areaAtuacao   AreaAtuacao @relation(fields: [areaAtuacaoId], references: [id])
  areaAtuacaoId String      @map("area_atuacao_id")
  criadoEm      DateTime    @default(now()) @map("criado_em")

  @@id([pesquisadorId, areaAtuacaoId])
  @@map("pesquisador_area_atuacao")
}

model MembroGrupo {
  pesquisador   Pesquisador   @relation(fields: [pesquisadorId], references: [id])
  pesquisadorId String        @map("pesquisador_id")
  grupoPesquisa GrupoPesquisa @relation(fields: [grupoId], references: [id])
  grupoId       String        @map("grupo_id")
  dataEntrada   DateTime?     @map("data_entrada")
  criadoEm      DateTime      @default(now()) @map("criado_em")
  atualizadoEm  DateTime      @updatedAt @map("atualizado_em")
  @@id([pesquisadorId, grupoId])
  @@map("membro_grupo")
}

model MembroLinhaPesquisa {
  linhaPesquisa   LinhaPesquisa @relation(fields: [linhaPesquisaId], references: [id])
  linhaPesquisaId String        @map("linha_pesquisa_id")
  pesquisador     Pesquisador   @relation(fields: [pesquisadorId], references: [id])
  pesquisadorId   String        @map("pesquisador_id")
  criadoEm        DateTime      @default(now()) @map("criado_em")

  @@id([linhaPesquisaId, pesquisadorId])
  @@map("membro_linha_pesquisa")
}

model AreaConhecimento {
  id             String             @id @default(uuid())
  nome           String
  codigo         String?            @unique
  nivel          Int?
  areaPai        AreaConhecimento?  @relation("AreaConhecimentoHierarquia", fields: [areaPaiId], references: [id])
  areaPaiId      String?            @map("area_pai_id")
  subareas       AreaConhecimento[] @relation("AreaConhecimentoHierarquia")
  gruposPesquisa GrupoPesquisa[]
  criadoEm       DateTime           @default(now()) @map("criado_em")
  atualizadoEm   DateTime           @updatedAt @map("atualizado_em")

  @@map("area_conhecimento")
}

model PalavraChave {
  id               String                      @id @default(uuid())
  termo            String                      @unique
  termoNormalizado String                      @unique @map("termo_normalizado")
  linhasPesquisa   LinhaPesquisaPalavraChave[]
  producoes        ProducaoPalavraChave[]
  criadoEm         DateTime                    @default(now()) @map("criado_em")
  atualizadoEm     DateTime                    @updatedAt @map("atualizado_em")

  @@map("palavra_chave")
}

model SetorAplicacao {
  id              String                        @id @default(uuid())
  nome            String                        @unique
  nomeNormalizado String                        @unique @map("nome_normalizado")
  linhasPesquisa  LinhaPesquisaSetorAplicacao[]
  criadoEm        DateTime                      @default(now()) @map("criado_em")
  atualizadoEm    DateTime                      @updatedAt @map("atualizado_em")

  @@map("setor_aplicacao")
}

model LinhaPesquisaSetorAplicacao {
  linhaPesquisa    LinhaPesquisa  @relation(fields: [linhaPesquisaId], references: [id])
  linhaPesquisaId  String         @map("linha_pesquisa_id")
  setorAplicacao   SetorAplicacao @relation(fields: [setorAplicacaoId], references: [id])
  setorAplicacaoId String         @map("setor_aplicacao_id")
  criadoEm         DateTime       @default(now()) @map("criado_em")

  @@id([linhaPesquisaId, setorAplicacaoId])
  @@map("linha_pesquisa_setor_aplicacao")
}

model LinhaPesquisaPalavraChave {
  linhaPesquisa   LinhaPesquisa @relation(fields: [linhaPesquisaId], references: [id])
  linhaPesquisaId String        @map("linha_pesquisa_id")
  palavraChave    PalavraChave  @relation(fields: [palavraChaveId], references: [id])
  palavraChaveId  String        @map("palavra_chave_id")
  criadoEm        DateTime      @default(now()) @map("criado_em")

  @@id([linhaPesquisaId, palavraChaveId])
  @@map("linha_pesquisa_palavra_chave")
}

enum TipoProducao {
  ARTIGO_PERIODICO   @map("artigo_periodico")
  ARTIGO_CONFERENCIA @map("artigo_conferencia")
  LIVRO              @map("livro")
  CAPITULO_LIVRO     @map("capitulo_livro")
  TRABALHO_TECNICO   @map("trabalho_tecnico")
  OUTRA              @map("outra")

  @@map("tipo_producao")
}

model Producao {
  id            String                 @id @default(uuid())
  titulo        String
  ano           Int?
  tipo          TipoProducao           @default(OUTRA)
  doi           String?                @unique
  url           String?
  veiculo       String?
  resumo        String?
  autores       ProducaoPesquisador[]
  palavrasChave ProducaoPalavraChave[]
  criadoEm      DateTime               @default(now()) @map("criado_em")
  atualizadoEm  DateTime               @updatedAt @map("atualizado_em")

  @@map("producao")
}

model ProducaoPesquisador {
  producao      Producao    @relation(fields: [producaoId], references: [id])
  producaoId    String      @map("producao_id")
  pesquisador   Pesquisador @relation(fields: [pesquisadorId], references: [id])
  pesquisadorId String      @map("pesquisador_id")
  ordemAutoria  Int?        @map("ordem_autoria")
  criadoEm      DateTime    @default(now()) @map("criado_em")

  @@id([producaoId, pesquisadorId])
  @@map("producao_pesquisador")
}

model ProducaoPalavraChave {
  producao       Producao     @relation(fields: [producaoId], references: [id])
  producaoId     String       @map("producao_id")
  palavraChave   PalavraChave @relation(fields: [palavraChaveId], references: [id])
  palavraChaveId String       @map("palavra_chave_id")
  criadoEm       DateTime     @default(now()) @map("criado_em")

  @@id([producaoId, palavraChaveId])
  @@map("producao_palavra_chave")
}

enum RagSourceType {
  GRUPO_PESQUISA    @map("grupo_pesquisa")
  LINHA_PESQUISA    @map("linha_pesquisa")
  PESQUISADOR       @map("pesquisador")
  PRODUCAO          @map("producao")
  AREA_CONHECIMENTO @map("area_conhecimento")

  @@map("rag_source_type")
}

enum IndexingJobStatus {
  PENDENTE     @map("pendente")
  EM_ANDAMENTO @map("em_andamento")
  CONCLUIDO    @map("concluido")
  ERRO         @map("erro")

  @@map("indexing_job_status")
}

model RagDocument {
  id           String        @id @default(uuid())
  sourceType   RagSourceType @map("source_type")
  sourceId     String        @map("source_id")
  titulo       String?
  conteudo     String?
  metadata     Json?
  chunks       RagChunk[]
  criadoEm     DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime      @updatedAt @map("atualizado_em")

  @@unique([sourceType, sourceId])
  @@index([sourceType, sourceId])
  @@map("rag_document")
}

model RagChunk {
  id           String                       @id @default(uuid())
  document     RagDocument                  @relation(fields: [documentId], references: [id])
  documentId   String                       @map("document_id")
  conteudo     String
  embedding    Unsupported("vector(1536)")?
  ordem        Int                          @default(0)
  tokenCount   Int?                         @map("token_count")
  metadata     Json?
  criadoEm     DateTime                     @default(now()) @map("criado_em")
  atualizadoEm DateTime                     @updatedAt @map("atualizado_em")

  @@index([documentId])
  @@map("rag_chunk")
}

model IndexingJob {
  id           String            @id @default(uuid())
  sourceType   RagSourceType     @map("source_type")
  sourceId     String            @map("source_id")
  status       IndexingJobStatus @default(PENDENTE)
  erro         String?
  tentativas   Int               @default(0)
  criadoEm     DateTime          @default(now()) @map("criado_em")
  atualizadoEm DateTime          @updatedAt @map("atualizado_em")

  @@index([status])
  @@index([sourceType, sourceId])
  @@map("indexing_job")
}

// Domínio do Scrapper

enum StatusColeta {
  EMANDAMENTO @map("em_andamento")
  CONCLUIDA    @map("concluida")

  @@map("status_coleta")
}

model ColetaScraper {
  id                   String           @id @default(uuid())
  dataInicio           DateTime         @map("data_inicio")
  dataFim              DateTime?         @map("data_fim")
  status               StatusColeta     @default(EMANDAMENTO)
  registrosProcessados Int              @map("registros_processados")
  logsColetaGrupo      LogColetaItem[]
  criadoEm             DateTime         @default(now()) @map("criado_em")
  atualizadoEm         DateTime         @updatedAt @map("atualizado_em")

  @@map("coleta_scraper")
}

enum LogColetaStatus {
  SUCESSO
  ERRO
}
enum LogColetaEntidade {
  PESQUISADOR
  GRUPO
}
model LogColetaItem {
  id            String                  @id @default(uuid())
  coletaScraper ColetaScraper           @relation(fields: [coletaId], references: [id])
  coletaId      String                  @map("coleta_id")
  grupo         GrupoPesquisa?          @relation("GrupoLogs", fields: [entidadeId], references: [dgpId], map: "fk_log_grupo", onDelete: NoAction, onUpdate: NoAction)
  pesquisador   Pesquisador?            @relation("PesquisadorLogs", fields: [entidadeId], references: [lattesId], map: "fk_log_pesquisador", onDelete: NoAction, onUpdate: NoAction)
  entidade      LogColetaEntidade         
  entidadeId    String                  @map("entidade_id")
  status        LogColetaStatus 
  criadoEm      DateTime                @default(now()) @map("criado_em")
  atualizadoEm  DateTime                @updatedAt @map("atualizado_em")
  @@index([entidade, entidadeId, status])
  @@map("log_coleta_grupo")
}

enum FilaExtracaoStatus {
  PENDENTE
  CONCLUIDO
  PROCESSANDO
}
model FilaExtracaoGrupo {
  dgpId             String @unique @id @map("dgp_id")
  nome              String
  area              String
  instituicao       String
  status            FilaExtracaoStatus   @default(PENDENTE)
  tentativas        Int      @default(0)
  similares         Int      @default(1)
  criadoEm          DateTime @default(now()) @map("criado_em")
  ultimaAtualizacao DateTime @default(now()) @updatedAt @map("ultima_atualizacao")

  @@map("fila_extracao_grupo")
}

model FilaExtracaoPesquisador {
  lattesId String @unique @id @map("lattes_id")
  nome String
  status FilaExtracaoStatus @default(PENDENTE)
  tentativas        Int      @default(0)
  criadoEm          DateTime @default(now()) @map("criado_em")
  ultimaAtualizacao DateTime @default(now()) @updatedAt @map("ultima_atualizacao")

  @@map("fila_extracao_pesquisador")
}
model StgGrupoPesquisa {
  id               Int     @id @default(autoincrement())
  dgp_id           String?
  nome             String?
  ano_formacao     Int?
  area_predominante String?
  repercussao      String?
  instituicao_nome String?
  estado               String?

  @@map("stg_grupo_pesquisa")
}

model StgPesquisador {
  id            Int     @id @default(autoincrement())
  dgp_id        String?
  nome          String?
  lattes_id     String?
  formacao      String?
  categoria     String?
  areas_atuacao String?

  @@map("stg_pesquisador")
}

model StgLinhaPesquisa {
  id               Int     @id @default(autoincrement())
  dgp_id           String?
  titulo           String?
  objetivo         String?
  setor_aplicacao  String?
  palavra_chave    String?

  @@map("stg_linha_pesquisa")
}
