{
  "name": "oda",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "build:all": "pnpm -r run build",
    "prisma:generate": "pnpm -F @oda/database run prisma:generate",
    "prisma:studio": "pnpm -F @oda/database run prisma:studio",
    "prisma:push": "pnpm -F @oda/database run prisma:push",
    "prisma:seed": "pnpm -F @oda/database run prisma:seed",
    "dev:api": "pnpm -F @oda/api start:dev",
    "dev:langchain": "pnpm -F @oda/langchain dev",
    "run:scraper": "pnpm -F @oda/scraper start",
    "scraper:dgp": "pnpm -F @oda/scraper start dgp",
    "scraper:discovery": "pnpm -F @oda/scraper start discovery",
    "scraper:lattes": "pnpm -F @oda/scraper start lattes",
    "etl": "pnpm -F @oda/etl start",
    "etl:grupo": "pnpm -F @oda/etl start grupo",
    "etl:pesquisador": "pnpm -F @oda/etl start pesquisador",
    "ingest:db": "pnpm -F @oda/langchain run ingest-db"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "bullmq": "^5.79.0",
    "dotenv": "^16.6.1"
  }
}
